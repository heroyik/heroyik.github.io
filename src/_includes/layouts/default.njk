  <body>
    <!-- Header removed -->


    <main>
        {{ content | safe }}
    </main>

    <!-- Scripts -->
    <script src="/assets/js/app.js"></script>
    <script type="module" src="/assets/vendor/model-viewer.min.js"></script>
  </body>
